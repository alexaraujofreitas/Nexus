# ============================================================
# NexusTrader Web — Environment Variables
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# For local development, the defaults in docker-compose.yml work.
# For production, ALL values below MUST be set explicitly.
# ============================================================

# PostgreSQL
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus
POSTGRES_DB=nexustrader

# Redis
REDIS_PASSWORD=changeme

# JWT Secret — MUST be 32+ characters in production
NEXUS_JWT_SECRET=dev-only-insecure-secret-do-not-use-in-prod!!

# Debug mode (true for dev, false for production)
NEXUS_DEBUG=true

# Encryption key (Fernet) — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
NEXUS_ENCRYPTION_KEY=
