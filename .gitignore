# ============================================================
# NexusTrader — .gitignore
# ============================================================
# SECURITY: Never commit API keys, secrets, or live trading data.
# The vault and encryption key are the most critical files to protect.

# ── Secrets & API keys (NEVER COMMIT) ─────────────────────
data/.nexus_vault.json
data/.nexus_key
Anthropic Key.txt
*.env
.env.*
**/secrets.json
**/credentials.json

# ── Live trading & account state ──────────────────────────
# These are machine-specific runtime files; each machine generates its own.
data/nexus_trader.db
data/nexus_trader.db-shm
data/nexus_trader.db-wal
data/open_positions.json
data/trade_outcomes.jsonl
data/outcome_tracker.json
data/level2_tracker.json

# ── Large binary / generated data ─────────────────────────
data/cache/
data/models/
reports/walk_forward/*.png
reports/walk_forward/*.html
reports/walk_forward/*.csv

# ── Log files (large and machine-specific) ────────────────
logs/nexus_trader.log
logs/nexus_trader.log.*

# ── Python cache and build artifacts ──────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyc
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
*.whl
.eggs/

# ── Pytest / test artifacts ────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.xml
junit*.xml

# ── Virtual environments ───────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ── IDEs ───────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# ── Windows temp / lock files ─────────────────────────────
~$*
*.tmp

# ── UI test artifacts (generated output) ──────────────────
# Screenshots, JSON reports, and PNGs from run_ui_checks.py / --test-ui
artifacts/

# ── Additional runtime data files ─────────────────────────
# These files store per-machine runtime state (adaptive weights, performance
# tracking, calibration data). Each machine generates its own from live trading.
data/trade_monitor.json
data/model_perf_tracker.json
data/filter_stats.json
data/live_vs_backtest.json
data/calibrator_monitor.json
data/scale_manager.json
data/strategy_audit.jsonl
data/backtest_results/
data/archive/
data/nexustrader.db
data/paper_trades.db

# ── Cowork / Agent tooling ────────────────────────────────
.agent/
.claude/
.venv-agent/

# ── Generated reports (machine-specific outputs) ───────────
reports/backtest_2yr/
reports/demo_validation/
reports/reviews/

# ── Temporary working files ────────────────────────────────
logs/EXTRACTED_*.txt
backtest_data/
backtest_results.json
study*_results.json
validation_report.json
migration_report.json
orders_positions.html
cache/
models/
regime_output/
archived_cps_experiment/
data/cda_observations.jsonl
data/destructive_audit.jsonl
data/live_open_positions.json
data/model_perf_tracker_pre_wave3_archive.json
data/outcome_tracker_pre_wave3_archive.json
data/phase2c_shadow_log.jsonl
data/scan_error_diag.txt
data/trade_lifecycle.jsonl
data/trade_log.jsonl
data/validation/
web/backend/TEST_RESULTS_*.txt
web/backend/data/
web/backend/pytest-cache-files-*
research/experiments/
research/harness/

# ── Misc clipboard / scratch files ────────────────────────
CUsersalexa*
claude mcp add*

# ── Linux FUSE mount artifacts (Cowork VM) ────────────────
# These .fuse_hidden* files appear in the Windows folder due to the
# Cowork VM mount. They are temporary Linux filesystem artifacts and
# must never be committed.
.fuse_hidden*

# ── Node.js / Frontend ────────────────────────────────────
node_modules/
playwright-report/
test-results/
.playwright/

# ── Jupyter ───────────────────────────────────────────────
.ipynb_checkpoints/

# ── Optional: local config overrides ──────────────────────
# Uncomment the line below if you want each machine to have
# its own settings.yaml (exchange keys, watchlists, etc.)
# config/settings.yaml

# ── Web frontend runtime data ─────────────────────────────
data/web_assets.json
